# ─────────────────────────────────────────────────────────────
#  Website Automation Agent — configuration
#  Copy this file to ".env" and fill in your values:
#      cp .env.example .env
# ─────────────────────────────────────────────────────────────

# REQUIRED for "agent" mode (the AI brain). Get a key at
# https://console.anthropic.com/ . Not needed for "deterministic" mode.
ANTHROPIC_API_KEY=

# Which Claude model the agent thinks with.
# claude-sonnet-4-6  -> best balance of price/speed (default, recommended)
# claude-opus-4-8    -> strongest browser-agent reliability, costs more
# claude-haiku-4-5   -> cheapest/fastest, fine for this simple task
MODEL=claude-sonnet-4-6

# ── FREE alternative brain: Groq ──────────────────────────────
# REQUIRED only for "groq" mode. Groq has a free tier (no credit card) —
# get a key at https://console.groq.com/ . Then run:  python main.py --mode groq
GROQ_API_KEY=
# A free Groq model with tool-calling support.
GROQ_MODEL=llama-3.3-70b-versatile

# The page the agent automates.
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# The values the agent will type into the form.
# NOTE: the target form validates length — the title must be 5-32 chars
# and the description must be 20-100 chars, or the form shows an error.
NAME_VALUE=Checkout button not working
DESCRIPTION_VALUE=Clicking the submit button on mobile does nothing and shows no error at all.

# Browser behaviour.
# HEADLESS=false lets you WATCH the browser during your viva demo.
HEADLESS=false
# Slows every action down by N milliseconds so the demo is easy to follow.
SLOW_MO_MS=400

# Safety rail: max number of think->act steps before the agent gives up.
MAX_STEPS=15

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
